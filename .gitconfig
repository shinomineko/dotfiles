[alias]
	st = status
	ci = commit
	co = checkout
	br = branch
	df = diff
	lg = log --oneline -n 20 --graph --abbrev-commit
	sw = switch
	undo = !git reset HEAD~1 --mixed
	amend = !git commit --amend --no-edit
	who = shortlog -sn --no-merges
	mostchanges = "!git log --format=format: --name-only --since=\"1 year ago\" | sort | uniq -c | sort -nr | head -20"

[color]
	ui = auto

[core]
	editor = $EDITOR
	excludesFile = ~/.gitignore
	pager = delta

[commit]
	gpgSign = true

[delta]
	navigate = true

[gpg]
	format = ssh

[init]
	defaultBranch = main

[pull]
	rebase = true
	default = current

[push]
	default = current

[user]
	name = shino
	email = sc@shinomin.me
	signingKey = ~/.ssh/id_ed25519.pub

[include]
	path = ~/.gitconfig.inc

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
